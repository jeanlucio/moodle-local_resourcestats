{{!
    @template local_resourcestats/preferences

    Form for choosing which statistics badges to display on the course page.

    Context variables required for this template:
    * options    - Array of {value, label, checked} for the radio buttons.
    * actionurl  - Form POST action URL.
    * returnurl  - URL to cancel back to.
    * sesskey    - Moodle session key for POST security.

    Example context (json):
    {
        "options": [
            {"value": "both",   "label": "Total de acessos + Alunos que acessaram", "checked": false, "isdefault": false},
            {"value": "total",  "label": "Somente total de acessos",                "checked": false, "isdefault": false},
            {"value": "unique", "label": "Somente alunos que acessaram",            "checked": true,  "isdefault": true},
            {"value": "none",   "label": "Não exibir nada",                         "checked": false, "isdefault": false}
        ],
        "actionurl": "/local/resourcestats/preferences.php",
        "returnurl": "/course/view.php?id=2",
        "sesskey":   "abc123"
    }
}}
<div class="local_resourcestats-preferences row justify-content-center mt-4">
    <div class="col-md-7 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark d-flex align-items-center">
                <i class="fa fa-cog me-2 text-white" aria-hidden="true"></i>
                <h2 class="h5 mb-0 text-white">{{#str}} preferences_title, local_resourcestats {{/str}}</h2>
            </div>
            <div class="card-body">
                <p class="text-muted mb-4">{{#str}} preferences_desc, local_resourcestats {{/str}}</p>
                <form method="post" action="{{actionurl}}">
                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                    <input type="hidden" name="returnurl" value="{{returnurl}}">
                    <fieldset class="border-0 p-0 m-0">
                        <legend class="local-resourcestats-hidden">{{#str}} preferences_title, local_resourcestats {{/str}}</legend>
                        {{#options}}
                        <div class="form-check mb-3">
                            <input class="form-check-input"
                                   type="radio"
                                   name="mode"
                                   id="local_resourcestats_mode_{{value}}"
                                   value="{{value}}"
                                   {{#checked}}checked{{/checked}}>
                            <label class="form-check-label" for="local_resourcestats_mode_{{value}}">
                                {{label}}{{#isdefault}} <span class="badge rounded-pill local-resourcestats-default-badge ms-1">{{#str}} default, local_resourcestats {{/str}}</span>{{/isdefault}}
                            </label>
                        </div>
                        {{/options}}
                    </fieldset>
                    <div class="d-flex mt-4">
                        <button type="submit" class="btn btn-primary me-2">
                            {{#str}} savechanges, core {{/str}}
                        </button>
                        <a href="{{returnurl}}" class="btn btn-secondary">
                            {{#str}} cancel, core {{/str}}
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
