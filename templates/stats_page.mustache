{{!
    @template local_resourcestats/stats_page

    Dedicated statistics page for a single course module, showing a
    per-student access table with first/last access dates and totals.

    Context variables required for this template:
    * cmname       - The name of the course module.
    * students     - Array of student rows: fullname, viewcount, firstviewtime, lastviewtime.
    * hasviews     - Boolean: true when at least one student has accessed the resource.
    * totalviews   - Sum of all individual accesses.
    * uniqueviews  - Number of distinct students.

    Example context (json):
    {
        "cmname": "Introduction to PHP",
        "hasviews": true,
        "totalviews": 9,
        "uniqueviews": 3,
        "students": [
            {
                "fullname": "NPC 01",
                "viewcount": 5,
                "firstviewtime": "28 April 2026, 10:00 AM",
                "lastviewtime": "28 April 2026, 5:00 PM"
            },
            {
                "fullname": "NPC 02",
                "viewcount": 2,
                "firstviewtime": "27 April 2026, 9:00 AM",
                "lastviewtime": "27 April 2026, 3:00 PM"
            }
        ],
        "hasdeletedrow": true,
        "deletedrow": {"label": "1 deleted student(s)", "viewcount": 2}
    }
}}
<div class="local_resourcestats-page mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-bg-primary d-flex align-items-center gap-2">
            <i class="fa fa-bar-chart" aria-hidden="true"></i>
            <h3 class="card-title h5 mb-0 text-white">
                {{#str}} statistics, local_resourcestats {{/str}} — {{cmname}}
            </h3>
        </div>
        <div class="card-body p-0">
            {{#hasviews}}
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">{{#str}} col_student, local_resourcestats {{/str}}</th>
                            <th scope="col" class="text-center">{{#str}} col_accesses, local_resourcestats {{/str}}</th>
                            <th scope="col">{{#str}} col_firstaccess, local_resourcestats {{/str}}</th>
                            <th scope="col">{{#str}} col_lastaccess, local_resourcestats {{/str}}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#students}}
                        <tr>
                            <td>{{fullname}}</td>
                            <td class="text-center fw-bold">{{viewcount}}</td>
                            <td>{{firstviewtime}}</td>
                            <td>{{lastviewtime}}</td>
                        </tr>
                        {{/students}}
                        {{#hasdeletedrow}}
                        <tr class="text-muted fst-italic">
                            <td>{{deletedrow.label}}</td>
                            <td class="text-center">{{deletedrow.viewcount}}</td>
                            <td colspan="2">—</td>
                        </tr>
                        {{/hasdeletedrow}}
                    </tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td>{{#str}} col_total, local_resourcestats {{/str}}</td>
                            <td class="text-center">{{totalviews}}</td>
                            <td colspan="2" class="text-muted fw-normal fst-italic">
                                {{#str}} unique_students, local_resourcestats, {{uniqueviews}} {{/str}}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            {{/hasviews}}
            {{^hasviews}}
            <p class="text-muted fst-italic p-4 mb-0">{{#str}} neverviewed, local_resourcestats {{/str}}</p>
            {{/hasviews}}
        </div>
    </div>
</div>
