{{!
    @template local_resourcestats/stats_page

    Dedicated statistics page for a single course module.

    Context variables required for this template:
    * totalviews  - The total number of views for the resource.
    * lastusername - The full name of the last user who viewed the resource.
    * lastviewtime - Human-readable timestamp of the last view.
    * hasviews    - Boolean flag indicating if the resource has been viewed at least once.
    * cmname      - The name of the course module.

    Example context (json):
    {
        "totalviews": 150,
        "lastusername": "Jean Lúcio",
        "lastviewtime": "28 April 2026, 5:00 PM",
        "hasviews": true,
        "cmname": "Introduction to PHP"
    }
}}
<div class="local_resourcestats-page mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header text-bg-primary d-flex align-items-center gap-2">
                    <i class="fa fa-bar-chart" aria-hidden="true"></i>
                    <h3 class="card-title h5 mb-0 text-white">
                        {{#str}} statistics, local_resourcestats {{/str}} — {{cmname}}
                    </h3>
                </div>
                <div class="card-body text-center py-5">
                    <div class="display-1 text-primary mb-2" aria-label="{{#str}} views, local_resourcestats {{/str}}: {{totalviews}}">
                        <i class="fa fa-eye" aria-hidden="true"></i>
                        <span>{{totalviews}}</span>
                    </div>
                    <p class="h5 text-muted mb-4">{{#str}} views, local_resourcestats {{/str}}</p>
                    {{#hasviews}}
                    <dl class="row justify-content-center mt-3 mb-0">
                        <dt class="col-sm-5 text-end text-muted">{{#str}} lastviewedby, local_resourcestats {{/str}}</dt>
                        <dd class="col-sm-7 text-start fw-bold">{{lastusername}}</dd>
                        {{#lastviewtime}}
                        <dt class="col-sm-5 text-end text-muted">{{#str}} lastviewtime, local_resourcestats {{/str}}</dt>
                        <dd class="col-sm-7 text-start">{{lastviewtime}}</dd>
                        {{/lastviewtime}}
                    </dl>
                    {{/hasviews}}
                    {{^hasviews}}
                    <p class="text-muted fst-italic">{{#str}} neverviewed, local_resourcestats {{/str}}</p>
                    {{/hasviews}}
                </div>
            </div>
        </div>
    </div>
</div>
